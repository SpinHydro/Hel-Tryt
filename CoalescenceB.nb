\)]\)\!\(\*SubscriptBox[\(|\), \(y = 0\)]\) [\!\(\*SuperscriptBox[\(MeV\), \
\(-3\)]\)]\>\"", ",", "Thick"}], "}"}]}], ",", 
    RowBox[{"PlotLabel", "\[Rule]", "\"\<Deuteron distribution\>\""}], ",", 
    RowBox[{"AxesStyle", "->", "Thick"}]}], "]"}]}]], "Input",
