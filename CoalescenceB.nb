Cell[BoxData[
 RowBox[{"DistributionDeuteronB", "=", 
  RowBox[{"LogPlot", "[", 
   RowBox[{
    RowBox[{"{", " ", 
     RowBox[{
      FractionBox["H2AfrB", 
       RowBox[{"2", "\[Pi]"}]], 
      RowBox[{"dNB", "[", 
       RowBox[{
        RowBox[{
         FractionBox["mt", "2"], "+", "mp"}], ",", "mp", ",", "\[Mu]pB", ",", 
        "0"}], "]"}], 
      RowBox[{"dNB", "[", 
       RowBox[{
        RowBox[{
         FractionBox["mt", "2"], "+", "mn"}], ",", "mn", ",", "\[Mu]nB", ",", 
        "0"}], "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"mt", ",", "0", ",", "700"}], "}"}], ",", 
    RowBox[{"PlotStyle", "\[Rule]", "Green"}], ",", 
    RowBox[{"AxesLabel", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
      "\"\<\!\(\*SubscriptBox[\(m\), \(t\)]\)-\!\(\*SubscriptBox[\(m\), \
\(0\)]\) [MeV]\>\"", ",", 
       "\"\<\!\(\*FractionBox[\(1\), SubscriptBox[SuperscriptBox[\(m\), \
