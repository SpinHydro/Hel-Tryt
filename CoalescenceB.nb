            RowBox[{"[", 
             RowBox[{"i", ",", "1"}], "]"}], "]"}], "]"}], 
          FractionBox[
           RowBox[{"He3AfrB", " "}], 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"2", "\[Pi]"}], ")"}], "2"]], 
          RowBox[{"dNB", "[", 
           RowBox[{
            RowBox[{
             FractionBox["mt", "3"], "+", "mp"}], ",", "mp", ",", "\[Mu]pB", 
            ",", 
            RowBox[{"TrytonsY", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "1"}], "]"}], "]"}]}], "]"}], 
          RowBox[{"dNB", "[", 
