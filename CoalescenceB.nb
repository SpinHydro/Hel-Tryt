Cell[BoxData[
 RowBox[{
  RowBox[{"He3DistributionB", "=", 
   RowBox[{"LogPlot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       FractionBox["He3AfrB", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"2", "\[Pi]"}], ")"}], "2"]], " ", 
