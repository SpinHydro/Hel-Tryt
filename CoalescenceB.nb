Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"RapidityDistributionB", "=", 
  RowBox[{"Quiet", "[", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"TrytonsY", "[", 
        RowBox[{"[", 
         RowBox[{"i", ",", "1"}], "]"}], "]"}], ",", 
       RowBox[{"NIntegrate", "[", 
        RowBox[{
         RowBox[{
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"mt", "+", "mp", "+", 
             RowBox[{"2", "mn"}]}], ")"}], "2"], 
          RowBox[{"Cosh", "[", 
           RowBox[{"TrytonsY", "[", 
            RowBox[{"[", 
             RowBox[{"i", ",", "1"}], "]"}], "]"}], "]"}], 
          FractionBox[
           RowBox[{"AfrB", " "}], 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"2", "\[Pi]"}], " ", ")"}], "2"]], 
          RowBox[{"dNB", "[", 
           RowBox[{
            RowBox[{
             FractionBox["mt", "3"], "+", "mp"}], ",", "mp", ",", "\[Mu]pB", 
            ",", 
            RowBox[{"TrytonsY", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "1"}], "]"}], "]"}]}], "]"}], 
          RowBox[{"dNB", "[", 
           RowBox[{
            RowBox[{
             FractionBox["mt", "3"], "+", "mn"}], ",", "mn", ",", "\[Mu]nB", 
            ",", 
            RowBox[{"TrytonsY", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "1"}], "]"}], "]"}]}], "]"}], 
          RowBox[{"dNB", "[", 
           RowBox[{
            RowBox[{
             FractionBox["mt", "3"], "+", "mn"}], ",", "mn", ",", "\[Mu]nB", 
            ",", 
            RowBox[{"TrytonsY", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "1"}], "]"}], "]"}]}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"mt", ",", "0", ",", "1000"}], "}"}]}], "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "13"}], "}"}]}], "]"}], "]"}]}]], "Input",
